## Foundry deployment environment (template)
## Create your own .env file from this (do NOT commit real keys)
##
## Notes:
## - PRIVATE_KEY should be WITHOUT the 0x prefix.
## - POLYGONSCAN_API_KEY is optional unless you want automatic verification.

PRIVATE_KEY=your_metamask_private_key_without_0x
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGONSCAN_API_KEY=your_polygonscan_api_key
INSTITUTION_NAME=XYZ University


