## Frontend Environment Configuration (Vite)
## DO NOT COMMIT this file - it contains sensitive configuration

VITE_BACKEND_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

## ⛓️ Smart Contract Configuration
## Get the contract address from deployment logs after running: forge create --chain=80001
## or from your deployment verification
VITE_CONTRACT_ADDRESS=0x/* YOUR_DEPLOYED_CONTRACT_ADDRESS_HERE */

## Default RPC URL for Polygon Mumbai (if needed on frontend)
VITE_RPC_URL=https://rpc-mumbai.maticvigil.com
